@implements IDisposable
@using PaperTradingBot.AI
@inject LiveSettingsService  Settings
@inject PerformanceTracker   Perf
@inject OptimizerStateService OptimizerState
@using Color = MudBlazor.Color
@using Size  = MudBlazor.Size

<MudPaper Elevation="0" Class="pa-4 mb-4" Style="background:#12121a;border:1px solid #1e1e2e;border-radius:12px;">

    <!-- header row -->
    <div class="d-flex align-center justify-space-between mb-3">
        <div class="d-flex align-center gap-2">
            <MudText Typo="Typo.subtitle2" Style="color:#9e9e9e;">AI OPTIMIZER</MudText>
            @if (OptimizerState.IsPaused)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                         Icon="@Icons.Material.Filled.Pause" Style="height:20px;font-size:0.68rem;">
                    PAUSED
                </MudChip>
            }
        </div>
        @{
            var rolling      = Perf.RollingReward();
            var rewardColor  = rolling > 0.05f ? Color.Success : rolling < -0.05f ? Color.Error : Color.Default;
            var rewardSign   = rolling >= 0 ? "+" : "";
        }
        <div class="d-flex align-center gap-2">
            <MudChip T="string" Size="Size.Small" Color="@rewardColor">
                Rolling @rewardSign@rolling.ToString("F3")
            </MudChip>
            <span style="font-size:0.72rem;color:#555;">@Perf.TotalRecorded cycles</span>
        </div>
    </div>

    <!-- credit failure banner -->
    @if (OptimizerState.InsufficientCredits)
    {
        <div class="d-flex align-center justify-space-between mb-3 pa-2"
             style="background:#2a1010;border:1px solid #7f1d1d;border-radius:8px;">
            <div>
                <div style="font-size:0.8rem;font-weight:600;color:#f87171;">
                    Claude API suspended — insufficient credits
                </div>
                <div style="font-size:0.72rem;color:#9a3333;margin-top:2px;">
                    Last attempt: @OptimizerState.LastAttemptAt.ToLocalTime().ToString("HH:mm dd-MMM")
                    &nbsp;·&nbsp;Top up at console.anthropic.com then press Retry
                </div>
            </div>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                       Style="min-width:56px;"
                       OnClick="@(() => OptimizerState.ClearCreditFailure())">
                Retry
            </MudButton>
        </div>
    }

    <!-- live settings drift -->
    @{
        var drifted = DriftedSettings().ToList();
    }
    <div style="font-size:0.68rem;letter-spacing:0.08em;color:#444;text-transform:uppercase;margin-bottom:6px;">
        Live settings (vs default)
    </div>
    @if (drifted.Count == 0)
    {
        <div style="font-size:0.78rem;color:#3a3a4a;margin-bottom:12px;">All at default.</div>
    }
    else
    {
        <div class="mb-3">
            @foreach (var r in drifted)
            {
                var delta     = r.Current - r.Default;
                var deltaSign = delta > 0 ? "+" : "";
                var color     = delta > 0 ? "#4caf50" : "#f44336";
                <div class="d-flex align-center gap-2"
                     style="font-size:0.8rem;padding:3px 0;border-bottom:1px solid #181828;">
                    <span style="color:#666;min-width:108px;">@r.Label</span>
                    <span style="color:#3a3a4a;">@r.Default.ToString(r.Format)</span>
                    <span style="color:#2a2a3a;">→</span>
                    <span style="color:@color;font-weight:600;">@r.Current.ToString(r.Format)</span>
                    <span style="color:@color;font-size:0.7rem;">
                        (@deltaSign@delta.ToString(r.Format))
                    </span>
                </div>
            }
        </div>
    }

    <!-- adjustment history -->
    <div style="font-size:0.68rem;letter-spacing:0.08em;color:#444;text-transform:uppercase;margin-bottom:6px;">
        Recent adjustments
    </div>
    @{
        var history = OptimizerState.GetHistory();
    }
    @if (history.Count == 0)
    {
        <div style="font-size:0.78rem;color:#3a3a4a;">No adjustments yet.</div>
    }
    else
    {
        @foreach (var adj in history.Take(8))
        {
            var srcColor = adj.Source == "Bandit" ? Color.Info : Color.Secondary;
            <div class="py-1" style="border-bottom:1px solid #181828;">
                <div class="d-flex align-center gap-2 flex-wrap">
                    <MudChip T="string" Size="Size.Small" Color="@srcColor"
                             Style="height:18px;font-size:0.68rem;padding:0 8px;min-height:0;">
                        @adj.Source
                    </MudChip>
                    <span style="color:#555;font-size:0.72rem;">
                        @adj.Timestamp.ToLocalTime().ToString("HH:mm dd-MMM")
                    </span>
                    @if (adj.Source == "NN" && adj.Reward != 0f)
                    {
                        var rc = adj.Reward > 0 ? "#4caf50" : "#f44336";
                        var rs = adj.Reward > 0 ? "+" : "";
                        <span style="font-size:0.72rem;color:@rc;">
                            r:@rs@adj.Reward.ToString("F3")
                        </span>
                    }
                </div>
                <div style="font-size:0.75rem;color:#aaa;font-family:monospace;margin-top:3px;word-break:break-all;">
                    @adj.Changes
                </div>
                @if (!string.IsNullOrWhiteSpace(adj.Reasoning))
                {
                    <div style="font-size:0.7rem;color:#555;margin-top:3px;font-style:italic;">
                        "@adj.Reasoning"
                    </div>
                }
            </div>
        }
    }

    <!-- controls -->
    <div class="d-flex gap-2 mt-3 pt-2" style="border-top:1px solid #181828;">
        @if (OptimizerState.IsPaused)
        {
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@(() => OptimizerState.SetPaused(false))">
                Resume
            </MudButton>
        }
        else
        {
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.Pause"
                       OnClick="@(() => OptimizerState.SetPaused(true))">
                Pause
            </MudButton>
        }
        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.RestartAlt"
                   OnClick="ResetToDefaults">
            Reset defaults
        </MudButton>
    </div>

    <!-- last Claude call (even if no changes) -->
    @if (OptimizerState.LastAttemptAt != DateTime.MinValue || OptimizerState.LastClaudeCallAt != DateTime.MinValue)
    {
        <div class="mt-3 pt-2" style="border-top:1px solid #181828;">
            @if (OptimizerState.LastAttemptAt != DateTime.MinValue)
            {
                <div class="d-flex align-center gap-2">
                    <span style="font-size:0.68rem;color:#444;text-transform:uppercase;letter-spacing:0.08em;">
                        Last attempt
                    </span>
                    <span style="font-size:0.72rem;color:#555;">
                        @OptimizerState.LastAttemptAt.ToLocalTime().ToString("HH:mm dd-MMM")
                    </span>
                    @if (OptimizerState.LastClaudeCallAt != DateTime.MinValue)
                    {
                        <span style="font-size:0.68rem;color:#444;text-transform:uppercase;letter-spacing:0.08em;margin-left:8px;">
                            Last success
                        </span>
                        <span style="font-size:0.72rem;color:#555;">
                            @OptimizerState.LastClaudeCallAt.ToLocalTime().ToString("HH:mm dd-MMM")
                        </span>
                    }
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(OptimizerState.LastClaudeReasoning))
            {
                <div style="font-size:0.7rem;color:#555;margin-top:4px;font-style:italic;">
                    "@OptimizerState.LastClaudeReasoning"
                </div>
            }
        </div>
    }

</MudPaper>

@code {
    protected override void OnInitialized()
    {
        OptimizerState.OnChanged += HandleChange;
    }

    public void Dispose()
    {
        OptimizerState.OnChanged -= HandleChange;
    }

    private async void HandleChange() => await InvokeAsync(StateHasChanged);

    private void ResetToDefaults()
    {
        Settings.ResetToDefaults();
        Settings.Save();   // overwrite file so restart also gets defaults
        StateHasChanged();
    }

    // ── Settings diff helpers ─────────────────────────────────────────────────

    private sealed record SettingRow(
        string  Label,
        decimal Default,
        decimal Current,
        string  Format,
        decimal DriftThreshold);

    private IEnumerable<SettingRow> DriftedSettings()
    {
        var s = Settings;
        SettingRow[] all =
        [
            new("RsiDipBuy",      40m,    s.RsiDipBuy,                  "F1",   0.1m),
            new("RsiCrossMax",    60m,    s.RsiCrossoverMax,            "F1",   0.1m),
            new("RsiCycleSell",   72m,    s.RsiCycleSell,               "F1",   0.1m),
            new("RsiCycleRebuy",  45m,    s.RsiCycleRebuy,              "F1",   0.1m),
            new("SellPct",        0.40m,  s.DefaultSellPct,             "P0",   0.005m),
            new("MinAbandon",     0.015m, s.MinAbandonRise,             "P2",   0.0005m),
            new("MaxAbandon",     0.045m, s.MaxAbandonRise,             "P2",   0.0005m),
            new("Cooldown",       10m,    (decimal)s.CycleCooldownBars, "F0",   0.5m),
        ];
        return all.Where(r => Math.Abs(r.Current - r.Default) >= r.DriftThreshold);
    }
}
