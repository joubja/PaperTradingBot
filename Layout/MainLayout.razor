@inherits LayoutComponentBase
@using Color = MudBlazor.Color
@using Size  = MudBlazor.Size

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark" Dense="true">
        <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:1px;">
            ₿ PaperTradingBot
        </MudText>
        <MudSpacer />
        <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Dashboard">Dashboard</MudButton>
        <MudButton Href="/history" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.History">History</MudButton>
        <MudButton Href="/settings" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Tune">Settings</MudButton>
        <MudSpacer />
        <MudText Typo="Typo.caption" Style="opacity:0.6;">paper trading — no real money</MudText>
    </MudAppBar>

    <MudMainContent Style="padding-top:64px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary        = "#00b4d8",
            Secondary      = "#90e0ef",
            Background     = "#0a0a0f",
            Surface        = "#12121a",
            DrawerBackground = "#0d0d14",
            AppbarBackground = "#0d0d14",
            TextPrimary    = "#e0e0e0",
            TextSecondary  = "#9e9e9e",
            ActionDefault  = "#e0e0e0",
            Divider        = "#2a2a3a",
            Success        = "#00e676",
            Error          = "#ff5252",
            Warning        = "#ffab40",
        },
        Typography = new Typography
        {
            Default = new Default { FontFamily = new[] { "Roboto", "sans-serif" } }
        }
    };
}
