@inherits LayoutComponentBase
@using Color = MudBlazor.Color
@using Size  = MudBlazor.Size
@using Microsoft.Extensions.Options
@using PaperTradingBot.Config
@inject IOptions<BotOptions> BotOpts

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark" Dense="true">
        <span style="display:flex;align-items:center;gap:7px;font-weight:700;letter-spacing:1px;font-size:1.1rem;color:#e0e0e0;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" style="flex-shrink:0;">
                <path fill="#00b4d8" d="M11.944 17.97L4.58 13.62 11.943 24l7.37-10.38-7.372 4.35h.003zM12.056 0L4.69 12.223l7.365 4.354 7.365-4.35L12.056 0z"/>
            </svg>
            AETHER
            @if (BotOpts.Value.Runtime.LocalPaperExecutionOnly)
            {
                <span style="font-size:0.7rem;font-weight:400;color:#ffab40;letter-spacing:2px;margin-left:2px;">— TEST</span>
            }
            else
            {
                <span style="font-size:0.7rem;font-weight:400;color:#00e676;letter-spacing:2px;margin-left:2px;">— LIVE</span>
            }
        </span>
        <MudSpacer />
        <MudTooltip Text="Dashboard">
            <MudIconButton Href="/" Icon="@Icons.Material.Filled.Dashboard" Color="Color.Inherit" Size="Size.Small" />
        </MudTooltip>
        <MudTooltip Text="History">
            <MudIconButton Href="/history" Icon="@Icons.Material.Filled.History" Color="Color.Inherit" Size="Size.Small" />
        </MudTooltip>
        <MudTooltip Text="Settings">
            <MudIconButton Href="/settings" Icon="@Icons.Material.Filled.Tune" Color="Color.Inherit" Size="Size.Small" />
        </MudTooltip>
    </MudAppBar>

    <MudMainContent Style="padding-top:64px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary        = "#00b4d8",
            Secondary      = "#90e0ef",
            Background     = "#0a0a0f",
            Surface        = "#12121a",
            DrawerBackground = "#0d0d14",
            AppbarBackground = "#0d0d14",
            TextPrimary    = "#e0e0e0",
            TextSecondary  = "#9e9e9e",
            ActionDefault  = "#e0e0e0",
            Divider        = "#2a2a3a",
            Success        = "#00e676",
            Error          = "#ff5252",
            Warning        = "#ffab40",
        },
        Typography = new Typography
        {
            Default = new Default { FontFamily = new[] { "Roboto", "sans-serif" } }
        }
    };
}
