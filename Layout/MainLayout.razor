@inherits LayoutComponentBase
@using Color = MudBlazor.Color
@using Size  = MudBlazor.Size
@using Microsoft.Extensions.Options
@using PaperTradingBot.Config
@inject IOptions<BotOptions> BotOpts

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark" Dense="true">
        @{
            var _isTest = BotOpts.Value.Runtime.LocalPaperExecutionOnly
                || BotOpts.Value.Providers.Binance.RestApiUrl.Contains("testnet", StringComparison.OrdinalIgnoreCase);
        }
        <span style="display:flex;align-items:center;gap:7px;font-weight:700;letter-spacing:1px;font-size:1.1rem;color:#e0e0e0;">
            @if (BotOpts.Value.Logo == "btc")
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" style="flex-shrink:0;">
                    <circle cx="12" cy="12" r="12" fill="#F7931A"/>
                    <path fill="white" d="M16.4 10.5c.25-.85-.4-1.35-1.05-1.65l.2-1.05-1.1-.2-.2.95c-.3-.05-.6-.1-.9-.15l.2-1H12.2l-.2 1c-.25-.05-.5-.1-.75-.1v-.01l-1.5-.3-.25 1.15s.8.15.78.18c.43.1.5.35.49.55l-.5 2.4c-.05.1-.15.25-.4.2.01.02-.78-.2-.78-.2l-.5 1.2 1.4.35c.27.07.52.13.77.2l-.2 1.05 1.1.2.2-1c.3.08.6.15.9.2l-.2 1 1.1.2.2-1.05c1.6.28 2.8-.05 3.3-1.3.4-1-.05-1.6-.8-1.95.55-.25.95-.7 1.05-1.5zm-2.2 2.8c-.28 1-2.1.5-2.7.35l.5-1.9c.6.15 2.5.45 2.2 1.55zm.3-2.85c-.25.9-1.8.46-2.3.35l.45-1.75c.5.1 2.1.35 1.85 1.4z"/>
                </svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" style="flex-shrink:0;">
                    <path fill="@BotOpts.Value.ThemeColor" d="M11.944 17.97L4.58 13.62 11.943 24l7.37-10.38-7.372 4.35h.003zM12.056 0L4.69 12.223l7.365 4.354 7.365-4.35L12.056 0z"/>
                </svg>
            }
            @BotOpts.Value.Name TradingBot
            <span style="font-size:0.7rem;font-weight:400;letter-spacing:2px;margin-left:2px;color:@(_isTest ? "#ffab40" : "#00e676");">
                — @(_isTest ? "TEST" : "LIVE")
            </span>
        </span>
        <MudSpacer />
        <MudButton Href="/" StartIcon="@Icons.Material.Filled.FactCheck" Color="Color.Inherit" Size="Size.Small">Reality Check</MudButton>
        <MudButton Href="/dashboard" StartIcon="@Icons.Material.Filled.Dashboard" Color="Color.Inherit" Size="Size.Small">Dashboard</MudButton>
        <MudButton Href="/history" StartIcon="@Icons.Material.Filled.History" Color="Color.Inherit" Size="Size.Small">History</MudButton>
        <MudButton Href="/settings" StartIcon="@Icons.Material.Filled.Tune" Color="Color.Inherit" Size="Size.Small">Settings</MudButton>
    </MudAppBar>

    <MudMainContent Style="padding-top:64px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme _theme = new();

    protected override void OnInitialized()
    {
        var color = BotOpts.Value.ThemeColor;
        _theme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary          = color,
                Secondary        = color,
                Background       = "#0a0a0f",
                Surface          = "#12121a",
                DrawerBackground = "#0d0d14",
                AppbarBackground = "#0d0d14",
                TextPrimary      = "#e0e0e0",
                TextSecondary    = "#9e9e9e",
                ActionDefault    = "#e0e0e0",
                Divider          = "#2a2a3a",
                Success          = "#00e676",
                Error            = "#ff5252",
                Warning          = "#ffab40",
            },
            Typography = new Typography
            {
                Default = new Default { FontFamily = new[] { "Roboto", "sans-serif" } }
            }
        };
    }
}
